# Copy this file to .env and fill in real values.
# The Makefile reads .env via --env-file when starting the sandbox.
# .env is gitignored — never commit real secrets.

# --- GitHub ------------------------------------------------------------------
# PAT with `repo` + `read:org` scopes. Used by github-mcp-server and by
# the self_improve commit step. When the konf-identity-github plugin
# lands, this will be replaced by a short-lived App installation token.
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- LLM providers -----------------------------------------------------------
# Gemini is the default for all ai:complete calls.
GEMINI_API_KEY=

# Anthropic is used only for self_improve.draft (persisted executable
# config — the one place where Claude Sonnet 4.6's instruction-following
# is worth the token cost) and by claude-cli itself if you log in with
# an API key.
ANTHROPIC_API_KEY=

# --- konf overrides ----------------------------------------------------------
# Per-call override is supported in ai:complete via `model:` in workflow
# YAML; this env var is the default if a workflow doesn't specify.
KONF_MODEL=gemini-2.5-pro

# Let rust logs through to container stdout so `make sandbox-logs` is useful.
RUST_LOG=info,konf=debug
